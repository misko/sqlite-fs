## `test_property_random_op_sequence_preserves_invariants(tmp_db)`
<!-- checksum: placeholder-dura-15 -->

### Purpose
Hypothesis stateful test: apply a random sequence of operations (mkdir, create, write, truncate, rename, unlink, link, setxattr) and after each sequence, assert every observable invariant from idea.md §Invariants holds.

### Postconditions

```python
from hypothesis import given, strategies as st, settings
from hypothesis.stateful import RuleBasedStateMachine, rule, invariant

class FsStateMachine(RuleBasedStateMachine):
    def __init__(self):
        super().__init__()
        mkfs(str(tmp_db), overwrite=True)
        self.fs = open_fs(str(tmp_db))
        self.fs.as_user(0, 0).__enter__()
        self.live_paths = ["/"]
        self.live_files = []

    @rule(name=st.text(alphabet="abc", min_size=1, max_size=3))
    def do_mkdir(self, name):
        path = f"/{name}"
        if path not in self.live_paths:
            self.fs.mkdir(path)
            self.live_paths.append(path)

    @rule()
    def check_no_cycle(self):
        report = self.fs.fsck()
        assert not any(i.kind == "cycle" for i in report.issues)

    @invariant()
    def sizes_match_blobs(self):
        for path in self.live_files:
            st = self.fs.stat(path)
            # blob sum == stat.size, exposed via library hook.
            assert st.size == self.fs._total_blob_bytes(st.inode)

    def teardown(self):
        self.fs.close()

settings(max_examples=25, deadline=None)(FsStateMachine.TestCase).run()
```

