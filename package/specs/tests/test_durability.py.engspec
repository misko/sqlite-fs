## `test_reopen_preserves_hardlinks(tmp_db)`
<!-- checksum: placeholder-dura-8 -->

### Postconditions

```python
mkfs(str(tmp_db))

fs = open_fs(str(tmp_db))
with fs.as_user(0, 0):
    fd = fs.create("/a"); fs.write(fd, b"content", offset=0); fs.close_fd(fd)
    fs.link("/a", "/b")
    inode = fs.stat("/a").inode
    assert fs.stat("/b").inode == inode
    assert fs.stat("/a").nlink == 2
fs.close()

fs = open_fs(str(tmp_db))
with fs.as_user(0, 0):
    assert fs.stat("/a").inode == fs.stat("/b").inode
    assert fs.stat("/a").nlink == 2
fs.close()
```

