## `pub fn stat(&self, path: &str) -> Result<Stat>`
<!-- checksum: rust-fs-4 -->

### Implementation Notes

```rust
impl Filesystem {
    pub fn stat(&self, path: &str) -> Result<Stat> {
        let ino = self.resolve_to_inode(path)?;
        let row = nodes::get(&self.conn, ino)?;
        Ok(Stat {
            kind:     row.kind,
            size:     row.size,
            mode:     row.mode,
            uid:      row.uid,
            gid:      row.gid,
            atime_ns: row.atime_ns,
            mtime_ns: row.mtime_ns,
            ctime_ns: row.ctime_ns,
            nlink:    row.nlink,
            inode:    row.inode,
        })
    }
}
```

