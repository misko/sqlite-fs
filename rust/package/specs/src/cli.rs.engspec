## `_export(db_path: str, dest: str) -> int`
<!-- checksum: cli-3 -->

### Purpose
Walk the filesystem tree and write every file/dir/symlink to the host filesystem at `dest`. Preserves mode, uid, gid (if root), mtimes, symlink targets.

### Preconditions
- `db_path` exists; `dest` does not exist OR is an empty directory.

### Postconditions
- `dest` is populated with the mirror of the sqlite-fs tree.

### Implementation Notes

```python
def _export(db_path, dest):
    import os as _os
    _os.makedirs(dest, exist_ok=True)
    with open_fs(db_path, readonly=True) as fs:
        _export_dir(fs, "/", dest)
    return 0


def _export_dir(fs, src_path, dest_path):
    import os as _os
    for entry in fs.readdir(src_path):
        sub_src = (src_path.rstrip("/") + "/" + entry.name
                   if src_path != "/" else "/" + entry.name)
        sub_dest = _os.path.join(dest_path, entry.name)
        if entry.kind == "dir":
            _os.makedirs(sub_dest, exist_ok=True)
            _export_dir(fs, sub_src, sub_dest)
        elif entry.kind == "symlink":
            target = fs.readlink(sub_src)
            _os.symlink(target, sub_dest)
        else:  # file
            # Stream in chunks.
            fd = fs.open(sub_src, flags=0)
            try:
                with open(sub_dest, "wb") as f:
                    offset = 0
                    while True:
                        chunk = fs.read(fd, size=64 * 1024, offset=offset)
                        if not chunk:
                            break
                        f.write(chunk)
                        offset += len(chunk)
            finally:
                fs.close_fd(fd)
        # Preserve metadata.
        st = fs.stat(sub_src, follow_symlinks=False)
        if entry.kind != "symlink":
            _os.chmod(sub_dest, st.mode & 0o7777)
```

